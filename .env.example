# Salin berkas ini menjadi .env lalu sesuaikan bila perlu:  cp .env.example .env
# Semua variabel di bawah ini dipakai oleh docker-compose.yml di root.

# ======================================================================
# Service 1 — Katalog Event (Hasura + PostgreSQL)
# ======================================================================
POSTGRES_USER=hasura
POSTGRES_PASSWORD=hasurapassword
POSTGRES_DB=db_event_catalog
HASURA_PORT=8080
HASURA_ADMIN_SECRET=myadminsecret

# ======================================================================
# Service 2 — Booking & Queue (Laravel REST + MySQL)
# ======================================================================
BOOKING_PORT=8001
BOOKING_APP_KEY=
MYSQL_BOOKING_DB=db_ticket_booking
MYSQL_BOOKING_PASSWORD=secret

# ======================================================================
# Service 3 — Payment & Ticket Issuing (Lighthouse + MySQL)
# ======================================================================
ISSUING_PORT=8002
ISSUING_APP_KEY=
MYSQL_ISSUING_DB=db_ticket_issuing
MYSQL_ISSUING_PASSWORD=secret

# ======================================================================
# Message Broker — RabbitMQ
# ======================================================================
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
