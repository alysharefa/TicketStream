{
	"info": {
		"_postman_id": "ts-all-services-2026",
		"name": "TicketStream — All Services (End-to-End)",
		"description": "Koleksi Postman gabungan untuk semua 3 microservice TicketStream.\n\nAlur End-to-End:\n1. Browse konser via Hasura GraphQL (S1)\n2. Buat booking via REST / GraphQL (S2)\n3. Cek status booking via GraphQL (S2)\n4. Cek tiket via GraphQL (S3)\n\nPort:\n- S1 Hasura: 8080\n- S2 Booking: 8001\n- S3 Payment: 8002\n- RabbitMQ: 15672",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "S1 — Katalog Event (Hasura GraphQL)",
			"item": [
				{
					"name": "1. Konser Tersedia (kuota > 0)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"{ concerts(where: {available_quota: {_gt: 0}}, order_by: {event_date: asc}) { id name venue event_date price available_quota artist { name genre } } }\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "2. Cari Konser (filter genre + keyword)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"query CariKonser($genre: String, $keyword: String) { concerts(where: {_and: [{artist: {genre: {_eq: $genre}}}, {name: {_ilike: $keyword}}]}) { id name venue event_date price available_quota artist { name } } }\",\n  \"variables\": { \"genre\": \"Pop\", \"keyword\": \"%konser%\" }\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "3. Detail Konser (by ID)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"{ concerts_by_pk(id: 1) { id name venue event_date price total_quota available_quota artist { id name genre } } }\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "4. Statistik Katalog (aggregate)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"{ concerts_aggregate { aggregate { count sum { available_quota } } } }\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "5. Kurangi Kuota (mutation anti-oversell)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"mutation KurangiKuota($id: Int!) { update_concerts(where: {id: {_eq: $id}, available_quota: {_gt: 0}}, _inc: {available_quota: -1}) { affected_rows returning { id name available_quota } } }\",\n  \"variables\": { \"id\": 1 }\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "6. Set Kuota (reset untuk testing)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"mutation SetKuota($id: Int!, $quota: Int!) { update_concerts_by_pk(pk_columns: {id: $id}, _set: {available_quota: $quota}) { id name available_quota total_quota } }\",\n  \"variables\": { \"id\": 5, \"quota\": 2 }\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "7. Tambah Konser Baru",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"mutation TambahKonser($name: String!, $artist_id: Int!, $venue: String!, $event_date: timestamptz!, $price: numeric!, $total_quota: Int!, $available_quota: Int!) { insert_concerts_one(object: {name: $name, artist_id: $artist_id, venue: $venue, event_date: $event_date, price: $price, total_quota: $total_quota, available_quota: $available_quota}) { id name artist { name } } }\",\n  \"variables\": { \"name\": \"Konser Spesial Tahun Baru\", \"artist_id\": 1, \"venue\": \"Monas, Jakarta\", \"event_date\": \"2026-12-31T20:00:00+07:00\", \"price\": 500000, \"total_quota\": 1000, \"available_quota\": 1000 }\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				},
				{
					"name": "8. Artis dengan Konser",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type",            "value": "application/json" },
							{ "key": "x-hasura-admin-secret",   "value": "myadminsecret"    }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"{ artists { id name genre concerts { id name event_date venue price available_quota } } }\"\n}"
						},
						"url": {
							"raw": "http://localhost:8080/v1/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["v1", "graphql"]
						}
					}
				}
			]
		},
