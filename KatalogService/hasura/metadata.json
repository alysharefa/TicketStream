{
  "type": "replace_metadata",
  "args": {
    "version": 3,
    "sources": [
      {
        "name": "default",
        "kind": "postgres",
        "configuration": {
          "connection_info": {
            "database_url": { "from_env": "HASURA_GRAPHQL_DATABASE_URL" },
            "isolation_level": "read-committed",
            "use_prepared_statements": true,
            "pool_settings": {
              "connection_lifetime": 600,
              "idle_timeout": 180,
              "max_connections": 50,
              "retries": 1
            }
          }
        },
        "tables": [
          {
            "table": { "schema": "public", "name": "artists" },
            "array_relationships": [
              {
                "name": "concerts",
                "using": {
                  "foreign_key_constraint_on": {
                    "column": "artist_id",
                    "table": { "schema": "public", "name": "concerts" }
                  }
                }
              }
            ]
          },
          {
            "table": { "schema": "public", "name": "concerts" },
            "object_relationships": [
              {
                "name": "artist",
                "using": { "foreign_key_constraint_on": "artist_id" }
              }
            ]
          }
        ]
      }
    ]
  }
}
